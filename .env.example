# Telegram API Credentials (Required - get from https://my.telegram.org/apps)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# --- Single Account (default) ---
# Session Management (Choose ONE)
# Option 1: File-based session (a .session file will be created)
TELEGRAM_SESSION_NAME=telegram_session
# Option 2: String-based session (if you generate one, e.g., using Telethon's string session generator)
TELEGRAM_SESSION_STRING=1231231232erfdfdffd

# --- Multiple Accounts (optional) ---
# Comma-separated account names. All accounts share the same API_ID/API_HASH above.
# Each account needs its own session string: TELEGRAM_{NAME}_SESSION_STRING=...
# TELEGRAM_ACCOUNTS=personal,work
# TELEGRAM_PERSONAL_SESSION_STRING=...
# TELEGRAM_WORK_SESSION_STRING=...

# --- HTTP Server with OAuth (for server.py) ---
# Public URL where this server is accessible (required for OAuth)
# MCP_SERVER_URL=https://mcp.example.com
# Bind address and port
# MCP_SERVER_HOST=0.0.0.0
# MCP_SERVER_PORT=8000
# Path to OAuth data persistence file
# MCP_OAUTH_DATA_PATH=oauth_data.json
